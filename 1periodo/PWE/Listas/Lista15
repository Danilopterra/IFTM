body {
    background-color: #fff;
    font-family: Arial, sans-serif;
}

.navbar {
    background-color: #000;
    padding: 15px 0;
    display: flex;
    justify-content: center;
}

.nav-list {
    list-style: none;
    display: flex;
    gap: 50px;
}

.nav-item a {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    color: #fff; 
    font-family: 'Oswald', sans-serif;
    transition: all 0.3s ease; 
    border-bottom: 3px solid transparent; 
    padding-bottom: 8px;
}

.nav-item i {
    font-size: 28px;
    margin-bottom: 10px;
    transition: transform 0.3s ease;
}

.nav-item.fb:hover a {
    color: #1877F2;
    border-bottom-color: #1877F2;
}

.nav-item.ig:hover a {
    color: #E4405F;
    border-bottom-color: #E4405F;
}


.nav-item.gm:hover a {
    color: #34A853;
    border-bottom-color: #34A853;
}


.nav-item.tw:hover a {
    color: #1DA1F2;
    border-bottom-color: #1DA1F2;
}


.nav-item.yt:hover a {
    color: #FF0000;
    border-bottom-color: #FF0000;
}

.nav-item:hover i {
    transform: scale(1.1);
}

.content {
    padding: 50px;
    font-size: 22px;
}
        </ul>
